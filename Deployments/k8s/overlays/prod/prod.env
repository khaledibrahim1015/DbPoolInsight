# dev.env
# ─────────────────────────────────────────────────────────────────────────────
# This file is consumed by secretGenerator in kustomization.yaml.
# Kustomize reads each KEY=VALUE line and injects them into the Secret.
#
# ⚠️  Do NOT commit real credentials. For CI/CD, inject this file at pipeline
#     runtime (e.g. write it from a vault secret before running kustomize build).
#
# ─────────────────────────────────────────────────────────────────────────────
SA_PASSWORD=StrongPassword123!!
TMS_Conn=Server=sqlserverdb;Database=observabilityDB;User Id=khaled;Password=StrongPassword123!!;TrustServerCertificate=True
TMSReplica_Conn=Server=sqlserverdb;Database=observabilityDB;User Id=khaled;Password=StrongPassword123!!;TrustServerCertificate=True